{
  "name": "websiteprev",
  "version": "0.1.4",
  "type": "module",
  "description": "CLI tool to capture website screenshots after deployment",
  "bin": {
    "websiteprev": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "puppeteer": "^22.0.0",
    "cloudinary": "^2.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["screenshot", "cli", "ci", "deployment", "preview"],
  "license": "MIT"
}
